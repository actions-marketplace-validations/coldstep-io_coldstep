# https://editorconfig.org — reduce accidental UTF-16 / CRLF-only drift on Windows.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.go]
indent_style = tab

[*.{ts,json}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
